# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # isar_flutter_libs: strip xattr before CodeSign (macOS Sequoia+ "resource fork, Finder information... detritus not allowed")
    if target.name == 'isar_flutter_libs'
      phase = target.new_shell_script_build_phase('Strip xattr for codesign')
      phase.shell_script = <<~SCRIPT
        xattr -cr "${PODS_XCFRAMEWORKS_BUILD_DIR}/isar_flutter_libs" 2>/dev/null || true
        xattr -cr "${BUILT_PRODUCTS_DIR}/isar_flutter_libs.framework" 2>/dev/null || true
      SCRIPT
      phase.run_only_for_deployment_postprocessing = '0'
    end
    # Pods-Runner: strip xattr on aggregate framework so CodeSign succeeds (macOS Sequoia+)
    if target.name == 'Pods-Runner'
      phase = target.new_shell_script_build_phase('Strip xattr Pods_Runner.framework')
      phase.shell_script = 'xattr -cr "${BUILT_PRODUCTS_DIR}/Pods_Runner.framework" 2>/dev/null || true'
      phase.run_only_for_deployment_postprocessing = '0'
    end
  end
  # macOS Sequoia+ codesign workaround: strip xattr after each framework copy in Pods embed script
  frameworks_sh = File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Runner', 'Pods-Runner-frameworks.sh')
  if File.exist?(frameworks_sh) && !File.read(frameworks_sh).include?('xattr -cr')
    content = File.read(frameworks_sh)
    needle = "\n\n  local basename\n  basename="
    patch = "\n\n  # Strip extended attributes (e.g. com.apple.provenance) so codesign succeeds on macOS Sequoia+\n  xattr -cr \"\${destination}/\$(basename \"\$1\")\" 2>/dev/null || true\n\n  local basename\n  basename="
    if content.include?(needle)
      content.sub!(needle, patch)
      File.write(frameworks_sh, content)
    end
  end
end
